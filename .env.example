# ========================
# Obrigatorio
# ========================
OPENAI_API_KEY=sk-your-key-here

# ========================
# OpenAI
# ========================
OPENAI_MODEL=gpt-4o-mini

# ========================
# FIPE / persistencia
# ========================
FIPE_API_BASE=https://parallelum.com.br/fipe/api/v1
DATABASE_URL=file:./fipeja.db

# ========================
# Identidade do bot
# ========================
BOT_NAME=FipeJá

# ========================
# Rate-limit FIPE (token bucket compartilhado)
# ========================
RATE_LIMIT_PER_MINUTE=30

# ========================
# Allow-list de JIDs (DESABILITADA por padrao)
# Vazio = bot publico. Para ativar, liste JIDs separados por virgula.
# Aceita formatos:
#   5511999999999@s.whatsapp.net
#   5511999999999
#   11999999999
# ALLOWED_JIDS=11999999999,11888888888
# ALLOWED_JIDS=
# Mensagem opcional retornada para JIDs nao autorizados. Vazio = silencio.
# ALLOW_LIST_DENY_MESSAGE=

# ========================
# Rate-limit por usuario (anti-abuso)
# ========================
USER_RATE_LIMIT_MSG_PER_MIN=30
USER_RATE_LIMIT_PDF_PER_HOUR=10

# ========================
# Tamanho maximo de PDF em bytes (default 16 MB)
# ========================
PDF_MAX_BYTES=16777216

# ========================
# Pepper opcional para hash de telefone em logs.
# Defina em prod com 32+ chars aleatorios. Sem isso, phoneId pode ser
# revertido por brute-force no range de telefones BR.
# ========================
# PHONE_HASH_PEPPER=
